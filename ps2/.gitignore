*.map

# Generated by bin2c. Regenerated at build time from the PS2SDK or from
# user-supplied assets -- and SOME embed copyrighted data, so never commit them:
#   doom1_wad.c    <- DOOM1.WAD                   (id Software)
#   demo_genmidi.c <- GENMIDI lump from DOOM1.WAD (id Software)
#   demo_song.c    <- the demo .mid              (its own copyright)
*.irx
audsrv_irx.c
libsd_irx.c
doom1_wad.c
demo_genmidi.c
demo_song.c

# Copyright: never commit game data. WADs/MIDIs are user-supplied.
*.wad
*.WAD
*.mid
*.MID
